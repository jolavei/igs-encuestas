# Plantilla. Copia a .env y completa con TUS valores. NUNCA pongas secretos reales aquí
# (este archivo SÍ se versiona). El .env real está en .gitignore.

# --- Base de datos (PostgreSQL) ---
DATABASE_URL="postgresql://USUARIO:CONTRASEÑA@HOST:5432/BASE?schema=public"
# Nube (Supabase/Railway/Neon): usa el connection string del proveedor.

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# Genera uno: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-largo"

# --- Google OAuth (produccion) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Login de desarrollo (sin Google) ---
# "true" habilita login por email sin password para probar local. NUNCA en prod.
# En producción: OMITE ambas variables (o ponlas en "false").
ENABLE_DEV_LOGIN="true"
NEXT_PUBLIC_ENABLE_DEV_LOGIN="true"

# --- Email del primer admin (se promueve a ADMIN en el seed/primer login) ---
BOOTSTRAP_ADMIN_EMAIL="tu-correo@dominio.cl"
